{
  "//": "Custom seccomp profile for the C++ sandbox runner.",
  "//1": "Deny-by-default ALLOWLIST: any syscall not listed returns EPERM.",
  "//2": "Generous enough to run the g++ toolchain (cc1plus/as/ld) AND the user",
  "//3": "binary in one container, but the dangerous syscalls are deliberately",
  "//4": "omitted: ptrace, mount/umount, pivot_root, chroot, unshare, setns,",
  "//5": "kexec_*, *_module, bpf, perf_event_open, *key*, userfaultfd,",
  "//6": "process_vm_*, iopl/ioperm, io_uring_*, reboot, swapon/off, and the",
  "//7": "whole socket family (network is already cut, this is defense in depth).",
  "//8": "clone3 is forced to ENOSYS so glibc cleanly falls back to clone().",
  "defaultAction": "SCMP_ACT_ERRNO",
  "defaultErrnoRet": 1,
  "archMap": [
    {
      "architecture": "SCMP_ARCH_X86_64",
      "subArchitectures": ["SCMP_ARCH_X86", "SCMP_ARCH_X32"]
    }
  ],
  "syscalls": [
    {
      "names": [
        "clone3"
      ],
      "action": "SCMP_ACT_ERRNO",
      "errnoRet": 38,
      "comment": "ENOSYS -> glibc falls back to the allowed clone()"
    },
    {
      "action": "SCMP_ACT_ALLOW",
      "names": [
        "accept4",
        "access",
        "arch_prctl",
        "brk",
        "capget",
        "capset",
        "chdir",
        "chmod",
        "clock_getres",
        "clock_gettime",
        "clock_nanosleep",
        "clone",
        "close",
        "close_range",
        "copy_file_range",
        "creat",
        "dup",
        "dup2",
        "dup3",
        "epoll_create",
        "epoll_create1",
        "epoll_ctl",
        "epoll_pwait",
        "epoll_pwait2",
        "epoll_wait",
        "eventfd",
        "eventfd2",
        "execve",
        "execveat",
        "exit",
        "exit_group",
        "faccessat",
        "faccessat2",
        "fadvise64",
        "fallocate",
        "fchdir",
