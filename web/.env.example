# Copy to web/.env. The publishable key is NOT a secret (it ships in the client
# bundle) — it's the same pk_test_… that lives in server/.env.

# Clerk publishable key (from the Clerk dashboard, or server/.env).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_aGVscGluZy1hbGJhY29yZS0zNC5jbGVyay5hY2NvdW50cy5kZXYk

# API origin. Leave empty in dev — the Vite proxy forwards /api to the backend.
# In production, set this to the API origin (e.g. https://api.example.com).
VITE_API_BASE=
